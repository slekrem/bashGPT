{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "/m:1"
      ],
      "options": {
        "env": {
          "PATH": "${env:HOME}/.dotnet:${env:PATH}",
          "DOTNET_ROOT": "${env:HOME}/.dotnet"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    }
  ]
}
